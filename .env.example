# Copiá este archivo a .env en local o definí las mismas variables en Hostinger (panel de despliegue → Variables de entorno).

# MySQL (mismo formato que usa Prisma)
# Ejemplo: mysql://USUARIO:CONTRASEÑA@HOST:3306/NOMBRE_BD
# En Hostinger, si el login falla por SSL, probá al final de la URL:
# ?sslaccept=accept_invalid_certificates
# (caracteres especiales en la contraseña: codificá con encodeURIComponent)
DATABASE_URL="mysql://user:password@localhost:3306/patron_gas"

# NextAuth — OBLIGATORIO en despliegue (sin esto verás "Server error / server configuration")
# URL pública exacta del sitio (con https), sin barra final
NEXTAUTH_URL="https://patrondelgas.com"
# Secreto aleatorio largo (ej.: openssl rand -base64 32). Debe ser NO vacío en el panel.
NEXTAUTH_SECRET="cambiá-por-un-secreto-largo-único"
# Algunos paneles usan este nombre; NextAuth también lo acepta como respaldo:
# AUTH_SECRET="mismo-valor-que-NEXTAUTH_SECRET"
